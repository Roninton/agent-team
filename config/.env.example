# ACP Platform 环境变量示例
# 将此文件复制为 .env 生效
# 优先级：环境变量 > config.yml > 默认值

# Server
ACP_SERVER_PORT=3001
ACP_SERVER_HOST=0.0.0.0
ACP_CORS_ORIGIN=http://localhost:5173

# Database
ACP_DB_PATH=./data/db/acp.sqlite

# Log
ACP_LOG_PATH=./data/logs
ACP_LOG_LEVEL=info

# Data
ACP_DATA_ROOT=./data

# Agent
ACP_MAX_AGENTS=10
ACP_AGENT_WORKDIR=./data/agents

# 配置文件路径（可选）
# ACP_CONFIG_FILE=/path/to/your/config.yml
